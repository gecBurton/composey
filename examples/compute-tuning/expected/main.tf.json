{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "api_lg": {
        "name": "/ecs/prod-compute-tuning-api",
        "retention_in_days": 7
      },
      "worker_lg": {
        "name": "/ecs/prod-compute-tuning-worker",
        "retention_in_days": 7
      }
    },
    "aws_ecs_service": {
      "api_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "api",
            "container_port": 8080,
            "target_group_arn": "${aws_lb_target_group.api_tg.arn}"
          }
        ],
        "name": "prod-compute-tuning-api",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.api_td.arn}"
      },
      "worker_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-compute-tuning-worker",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.worker_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "api_td": {
        "container_definitions": "[{\"name\": \"api\", \"image\": \"my-api:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 8080, \"hostPort\": 8080, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.api_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "1024",
        "execution_role_arn": "${aws_iam_role.api_exec_role.arn}",
        "family": "prod-compute-tuning-api",
        "memory": "2048",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.api_task_role.arn}"
      },
      "worker_td": {
        "container_definitions": "[{\"name\": \"worker\", \"image\": \"my-worker:latest\", \"essential\": true, \"portMappings\": [], \"environment\": [], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.worker_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "1024",
        "execution_role_arn": "${aws_iam_role.worker_exec_role.arn}",
        "family": "prod-compute-tuning-worker",
        "memory": "4096",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.worker_task_role.arn}"
      }
    },
    "aws_iam_role": {
      "api_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-compute-tuning-api-exec-role"
      },
      "api_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-compute-tuning-api-task-role"
      },
      "worker_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-compute-tuning-worker-exec-role"
      },
      "worker_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-compute-tuning-worker-task-role"
      }
    },
    "aws_iam_role_policy": {
      "api_exec_log_policy": {
        "name": "prod-compute-tuning-api-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.api_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.api_exec_role.name}"
      },
      "worker_exec_log_policy": {
        "name": "prod-compute-tuning-worker-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.worker_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.worker_exec_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "api_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.api_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "api_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-compute-tuning-api-tg",
        "port": 8080,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for compute-tuning in prod",
        "name": "prod-compute-tuning-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_api_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to api",
        "from_port": 8080,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 8080,
        "type": "ingress"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}