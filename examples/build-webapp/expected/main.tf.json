{
  "data": {
    "aws_ecr_authorization_token": {
      "token": {}
    }
  },
  "provider": {
    "aws": {
      "region": "us-east-1"
    },
    "docker": {
      "registry_auth": {
        "address": "${data.aws_ecr_authorization_token.token.proxy_endpoint}",
        "password": "${data.aws_ecr_authorization_token.token.password}",
        "username": "${data.aws_ecr_authorization_token.token.user_name}"
      }
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "web_lg": {
        "name": "/ecs/prod-build-webapp-web",
        "retention_in_days": 7
      }
    },
    "aws_ecr_repository": {
      "web_ecr": {
        "force_delete": true,
        "image_tag_mutability": "MUTABLE",
        "name": "prod-build-webapp-web"
      }
    },
    "aws_ecs_service": {
      "web_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "web",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}"
          }
        ],
        "name": "prod-build-webapp-web",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.web_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "web_td": {
        "container_definitions": "[{\"name\": \"web\", \"image\": \"${aws_ecr_repository.web_ecr.repository_url}@${docker_registry_image.web_push.sha256_digest}\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.web_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.web_exec_role.arn}",
        "family": "prod-build-webapp-web",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.web_task_role.arn}"
      }
    },
    "aws_iam_role": {
      "web_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-build-webapp-web-exec-role"
      },
      "web_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-build-webapp-web-task-role"
      }
    },
    "aws_iam_role_policy": {
      "web_exec_ecr_policy": {
        "name": "prod-build-webapp-web-exec-ecr-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"ecr:GetAuthorizationToken\", \"ecr:BatchCheckLayerAvailability\", \"ecr:GetDownloadUrlForLayer\", \"ecr:BatchGetImage\"], \"Resource\": \"*\"}]}",
        "role": "${aws_iam_role.web_exec_role.name}"
      },
      "web_exec_log_policy": {
        "name": "prod-build-webapp-web-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.web_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.web_exec_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "web_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "web_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-build-webapp-web-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for build-webapp in prod",
        "name": "prod-build-webapp-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_web_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to web",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "app_egress_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow all outbound for build-webapp in prod",
        "from_port": 0,
        "protocol": "-1",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 0,
        "type": "egress"
      }
    },
    "docker_image": {
      "web_image": {
        "build": {
          "context": "app",
          "platform": "linux/amd64"
        },
        "name": "${aws_ecr_repository.web_ecr.repository_url}:latest"
      }
    },
    "docker_registry_image": {
      "web_push": {
        "keep_remotely": true,
        "name": "${docker_image.web_image.name}"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "docker": {
        "source": "kreuzwerker/docker",
        "version": "~> 3.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}