{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_db_instance": {
      "db_db": {
        "allocated_storage": 20,
        "db_subnet_group_name": "${aws_db_subnet_group.db_sng.name}",
        "engine": "mariadb",
        "identifier": "prod-nginx-flask-mysql-db",
        "instance_class": "db.t3.micro",
        "password": "${aws_secretsmanager_secret.db_db_password.id}",
        "publicly_accessible": false,
        "skip_final_snapshot": true,
        "username": "admin",
        "vpc_security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ]
      }
    },
    "aws_db_subnet_group": {
      "db_sng": {
        "name": "prod-nginx-flask-mysql-db-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ]
      }
    },
    "aws_ecs_service": {
      "backend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-nginx-flask-mysql-backend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.backend_td.arn}"
      },
      "proxy_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "proxy",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.proxy_tg.arn}"
          }
        ],
        "name": "prod-nginx-flask-mysql-proxy",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.proxy_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "backend_td": {
        "container_definitions": "[{\"name\": \"backend\", \"image\": \"flask-backend:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 8000, \"hostPort\": 8000, \"protocol\": \"tcp\"}], \"environment\": [{\"name\": \"DATABASE_HOST\", \"value\": \"${aws_db_instance.db_db.address}\"}], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.backend_exec_role.arn}",
        "family": "prod-nginx-flask-mysql-backend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.backend_task_role.arn}"
      },
      "proxy_td": {
        "container_definitions": "[{\"name\": \"proxy\", \"image\": \"nginx-proxy:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.proxy_exec_role.arn}",
        "family": "prod-nginx-flask-mysql-proxy",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.proxy_task_role.arn}"
      }
    },
    "aws_iam_role": {
      "backend_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-nginx-flask-mysql-backend-exec-role"
      },
      "backend_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-nginx-flask-mysql-backend-task-role"
      },
      "proxy_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-nginx-flask-mysql-proxy-exec-role"
      },
      "proxy_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-nginx-flask-mysql-proxy-task-role"
      }
    },
    "aws_lb_listener_rule": {
      "proxy_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.proxy_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "proxy_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-nginx-flask-mysql-proxy-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_secretsmanager_secret": {
      "db_db_password": {
        "description": "Master password for db RDS",
        "name": "prod-nginx-flask-mysql-db-db-password"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for nginx-flask-mysql in prod",
        "name": "prod-nginx-flask-mysql-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_proxy_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to proxy",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "backend_to_db_rule": {
        "description": "Allow backend to talk to db",
        "from_port": 3306,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 3306,
        "type": "ingress"
      },
      "proxy_to_backend_rule": {
        "description": "Allow proxy to talk to backend",
        "from_port": 8000,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 8000,
        "type": "ingress"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  }
}