{
  "resource": {
    "aws_cloudwatch_log_group": {},
    "aws_ecs_service": {
      "backend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-nginx-flask-mysql-backend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.backend_td.arn}"
      },
      "db_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-nginx-flask-mysql-db",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.db_td.arn}"
      },
      "proxy_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "proxy",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.proxy_tg.arn}"
          }
        ],
        "name": "prod-nginx-flask-mysql-proxy",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.proxy_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "backend_td": {
        "container_definitions": "[{\"name\": \"backend\", \"image\": \"flask-backend:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 8000, \"hostPort\": 8000, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-nginx-flask-mysql-backend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      },
      "db_td": {
        "container_definitions": "[{\"name\": \"db\", \"image\": \"mariadb:10-focal\", \"essential\": true, \"portMappings\": [], \"environment\": [{\"name\": \"MYSQL_DATABASE\", \"value\": \"example\"}], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-nginx-flask-mysql-db",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      },
      "proxy_td": {
        "container_definitions": "[{\"name\": \"proxy\", \"image\": \"nginx-proxy:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-nginx-flask-mysql-proxy",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      }
    },
    "aws_iam_role_policy": {},
    "aws_lb_listener_rule": {
      "proxy_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.proxy_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "proxy_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-nginx-flask-mysql-proxy-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_s3_bucket": {},
    "aws_secretsmanager_secret": {},
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for nginx-flask-mysql in prod",
        "name": "prod-nginx-flask-mysql-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_proxy_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to proxy",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "backend_to_db_rule": {
        "description": "Allow backend to talk to db",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "proxy_to_backend_rule": {
        "description": "Allow proxy to talk to backend",
        "from_port": 8000,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 8000,
        "type": "ingress"
      }
    }
  }
}