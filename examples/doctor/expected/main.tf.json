{
  "data": {
    "aws_ecr_authorization_token": {
      "token": {}
    }
  },
  "provider": {
    "aws": {
      "region": "us-east-1"
    },
    "docker": {
      "registry_auth": {
        "address": "${data.aws_ecr_authorization_token.token.proxy_endpoint}",
        "password": "${data.aws_ecr_authorization_token.token.password}",
        "username": "${data.aws_ecr_authorization_token.token.user_name}"
      }
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "doctor_lg": {
        "name": "/ecs/prod-doctor-doctor",
        "retention_in_days": 7
      }
    },
    "aws_db_instance": {
      "db_db": {
        "allocated_storage": 20,
        "db_subnet_group_name": "${aws_db_subnet_group.db_sng.name}",
        "engine": "postgres",
        "identifier": "prod-doctor-db",
        "instance_class": "db.t3.micro",
        "password": "${random_password.db_password.result}",
        "publicly_accessible": false,
        "skip_final_snapshot": true,
        "username": "composey",
        "vpc_security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ]
      }
    },
    "aws_db_subnet_group": {
      "db_sng": {
        "name": "prod-doctor-db-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ]
      }
    },
    "aws_ecr_repository": {
      "doctor_ecr": {
        "force_delete": true,
        "image_tag_mutability": "MUTABLE",
        "name": "prod-doctor-doctor"
      }
    },
    "aws_ecs_service": {
      "doctor_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "health_check_grace_period_seconds": 120,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "doctor",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.doctor_tg.arn}"
          }
        ],
        "name": "prod-doctor-doctor",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.doctor_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "doctor_td": {
        "container_definitions": "[{\"name\": \"doctor\", \"image\": \"${aws_ecr_repository.doctor_ecr.repository_url}@${docker_registry_image.doctor_push.sha256_digest}\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [{\"name\": \"BUCKET_NAME\", \"value\": \"${aws_s3_bucket.blobs_bucket.id}\"}, {\"name\": \"DB_HOST\", \"value\": \"${aws_db_instance.db_db.address}\"}, {\"name\": \"REDIS_URL\", \"value\": \"redis://${aws_elasticache_cluster.cache_cache.cache_nodes[0].address}:6379\"}], \"secrets\": [{\"name\": \"DB_PASSWORD\", \"valueFrom\": \"${aws_secretsmanager_secret.db_db_secret.arn}:password::\"}, {\"name\": \"DB_USERNAME\", \"valueFrom\": \"${aws_secretsmanager_secret.db_db_secret.arn}:username::\"}], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.doctor_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.doctor_exec_role.arn}",
        "family": "prod-doctor-doctor",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.doctor_task_role.arn}"
      }
    },
    "aws_elasticache_cluster": {
      "cache_cache": {
        "cluster_id": "prod-doctor-cache",
        "engine": "redis",
        "node_type": "cache.t3.micro",
        "num_cache_nodes": 1,
        "security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ],
        "subnet_group_name": "${aws_elasticache_subnet_group.cache_sng.name}"
      }
    },
    "aws_elasticache_subnet_group": {
      "cache_sng": {
        "name": "prod-doctor-cache-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ]
      }
    },
    "aws_iam_role": {
      "doctor_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-doctor-doctor-exec-role"
      },
      "doctor_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-doctor-doctor-task-role"
      }
    },
    "aws_iam_role_policy": {
      "doctor_exec_ecr_policy": {
        "name": "prod-doctor-doctor-exec-ecr-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"ecr:GetAuthorizationToken\", \"ecr:BatchCheckLayerAvailability\", \"ecr:GetDownloadUrlForLayer\", \"ecr:BatchGetImage\"], \"Resource\": \"*\"}]}",
        "role": "${aws_iam_role.doctor_exec_role.name}"
      },
      "doctor_exec_log_policy": {
        "name": "prod-doctor-doctor-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.doctor_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.doctor_exec_role.name}"
      },
      "doctor_to_blobs_s3_policy": {
        "name": "prod-doctor-doctor-blobs-s3-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.blobs_bucket.arn}\", \"${aws_s3_bucket.blobs_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.doctor_task_role.name}"
      },
      "doctor_to_db_rds_secret": {
        "name": "prod-doctor-doctor-db-rds-secret",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"secretsmanager:GetSecretValue\"], \"Resource\": [\"${aws_secretsmanager_secret.db_db_secret.arn}\"]}]}",
        "role": "${aws_iam_role.doctor_exec_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "doctor_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.doctor_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "doctor_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-doctor-doctor-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_s3_bucket": {
      "blobs_bucket": {
        "bucket": "prod-doctor-blobs",
        "force_destroy": true
      }
    },
    "aws_secretsmanager_secret": {
      "db_db_secret": {
        "description": "Credentials for db RDS",
        "name": "prod-doctor-db-credentials",
        "recovery_window_in_days": 0
      }
    },
    "aws_secretsmanager_secret_version": {
      "db_db_secret_v1": {
        "secret_id": "${aws_secretsmanager_secret.db_db_secret.id}",
        "secret_string": "{\"username\": \"composey\", \"password\": \"${random_password.db_password.result}\", \"engine\": \"postgres\"}"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for doctor in prod",
        "name": "prod-doctor-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_doctor_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to doctor",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "app_egress_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow all outbound for doctor in prod",
        "from_port": 0,
        "protocol": "-1",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 0,
        "type": "egress"
      },
      "doctor_to_cache_rule": {
        "description": "Allow doctor to talk to cache",
        "from_port": 6379,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 6379,
        "type": "ingress"
      },
      "doctor_to_db_rule": {
        "description": "Allow doctor to talk to db",
        "from_port": 5432,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 5432,
        "type": "ingress"
      }
    },
    "docker_image": {
      "doctor_image": {
        "build": {
          "context": "app",
          "platform": "linux/amd64"
        },
        "name": "${aws_ecr_repository.doctor_ecr.repository_url}:latest"
      }
    },
    "docker_registry_image": {
      "doctor_push": {
        "keep_remotely": true,
        "name": "${docker_image.doctor_image.name}"
      }
    },
    "random_password": {
      "db_password": {
        "length": 20,
        "special": false
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "docker": {
        "source": "kreuzwerker/docker",
        "version": "~> 3.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}