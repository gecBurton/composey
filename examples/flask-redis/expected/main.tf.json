{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_ecs_service": {
      "redis_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-flask-redis-redis",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.redis_td.arn}"
      },
      "web_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "web",
            "container_port": 8000,
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}"
          }
        ],
        "name": "prod-flask-redis-web",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.web_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "redis_td": {
        "container_definitions": "[{\"name\": \"redis\", \"image\": \"redislabs/redismod\", \"essential\": true, \"portMappings\": [{\"containerPort\": 6379, \"hostPort\": 6379, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-flask-redis-redis",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      },
      "web_td": {
        "container_definitions": "[{\"name\": \"web\", \"image\": \"flask-redis-web:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 8000, \"hostPort\": 8000, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-flask-redis-web",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      }
    },
    "aws_lb_listener_rule": {
      "web_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "web_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-flask-redis-web-tg",
        "port": 8000,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for flask-redis in prod",
        "name": "prod-flask-redis-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_web_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to web",
        "from_port": 8000,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 8000,
        "type": "ingress"
      },
      "web_to_redis_rule": {
        "description": "Allow web to talk to redis",
        "from_port": 6379,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 6379,
        "type": "ingress"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  }
}