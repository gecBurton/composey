{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "web_lg": {
        "name": "/ecs/prod-flask-redis-web",
        "retention_in_days": 7
      }
    },
    "aws_ecs_service": {
      "web_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "web",
            "container_port": 8000,
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}"
          }
        ],
        "name": "prod-flask-redis-web",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.web_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "web_td": {
        "container_definitions": "[{\"name\": \"web\", \"image\": \"flask-redis-web:latest\", \"essential\": true, \"portMappings\": [{\"containerPort\": 8000, \"hostPort\": 8000, \"protocol\": \"tcp\"}], \"environment\": [{\"name\": \"REDIS_HOST\", \"value\": \"${aws_elasticache_cluster.redis_cache.cache_nodes[0].address}\"}], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.web_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.web_exec_role.arn}",
        "family": "prod-flask-redis-web",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.web_task_role.arn}"
      }
    },
    "aws_elasticache_cluster": {
      "redis_cache": {
        "cluster_id": "prod-flask-redis-redis",
        "engine": "redis",
        "node_type": "cache.t3.micro",
        "num_cache_nodes": 1,
        "security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ],
        "subnet_group_name": "${aws_elasticache_subnet_group.redis_sng.name}"
      }
    },
    "aws_elasticache_subnet_group": {
      "redis_sng": {
        "name": "prod-flask-redis-redis-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ]
      }
    },
    "aws_iam_role": {
      "web_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-redis-web-exec-role"
      },
      "web_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-redis-web-task-role"
      }
    },
    "aws_iam_role_policy": {
      "web_exec_log_policy": {
        "name": "prod-flask-redis-web-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.web_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.web_exec_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "web_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "web_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-flask-redis-web-tg",
        "port": 8000,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for flask-redis in prod",
        "name": "prod-flask-redis-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_web_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to web",
        "from_port": 8000,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 8000,
        "type": "ingress"
      },
      "web_to_redis_rule": {
        "description": "Allow web to talk to redis",
        "from_port": 6379,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 6379,
        "type": "ingress"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}