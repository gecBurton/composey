{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "web_lg": {
        "name": "/ecs/prod-scaling-web",
        "retention_in_days": 7,
        "tags": {}
      }
    },
    "aws_db_instance": {
      "db_db": {
        "allocated_storage": 20,
        "db_subnet_group_name": "${aws_db_subnet_group.db_sng.name}",
        "engine": "postgres",
        "identifier": "prod-scaling-db",
        "instance_class": "db.t3.medium",
        "password": "${random_password.db_password.result}",
        "publicly_accessible": false,
        "skip_final_snapshot": true,
        "tags": {},
        "username": "admin",
        "vpc_security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ]
      }
    },
    "aws_db_subnet_group": {
      "db_sng": {
        "name": "prod-scaling-db-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ],
        "tags": {}
      }
    },
    "aws_ecs_service": {
      "web_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "web",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}"
          }
        ],
        "name": "prod-scaling-web",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "tags": {},
        "task_definition": "${aws_ecs_task_definition.web_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "web_td": {
        "container_definitions": "[{\"name\": \"web\", \"image\": \"nginx\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.web_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "4096",
        "execution_role_arn": "${aws_iam_role.web_exec_role.arn}",
        "family": "prod-scaling-web",
        "memory": "8192",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "tags": {},
        "task_role_arn": "${aws_iam_role.web_task_role.arn}"
      }
    },
    "aws_iam_role": {
      "web_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-scaling-web-exec-role",
        "tags": {}
      },
      "web_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-scaling-web-task-role",
        "tags": {}
      }
    },
    "aws_iam_role_policy": {
      "web_exec_log_policy": {
        "name": "prod-scaling-web-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.web_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.web_exec_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "web_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.web_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100,
        "tags": {}
      }
    },
    "aws_lb_target_group": {
      "web_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-scaling-web-tg",
        "port": 80,
        "protocol": "HTTP",
        "tags": {},
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_secretsmanager_secret": {
      "db_db_secret": {
        "description": "Credentials for db RDS",
        "name": "prod-scaling-db-credentials",
        "tags": {}
      }
    },
    "aws_secretsmanager_secret_version": {
      "db_db_secret_v1": {
        "secret_id": "${aws_secretsmanager_secret.db_db_secret.id}",
        "secret_string": "{\"username\": \"admin\", \"password\": \"${random_password.db_password.result}\", \"engine\": \"postgres\"}"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for scaling in prod",
        "name": "prod-scaling-sg",
        "tags": {},
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_web_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to web",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      }
    },
    "random_password": {
      "db_password": {
        "length": 20,
        "special": false
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}