{
  "name": "flask",
  "networks": {
    "private": {
      "name": "flask_private",
      "ipam": {}
    },
    "public": {
      "name": "flask_public",
      "ipam": {}
    }
  },
  "secrets": {
    "db-password": {
      "name": "flask_db-password",
      "file": "db/password.txt"
    }
  },
  "services": {
    "backend": {
      "build": {
        "context": "backend",
        "dockerfile": "Dockerfile",
        "args": {
          "NODE_ENV": "development"
        },
        "target": "development"
      },
      "command": [
        "npm",
        "run",
        "start-watch"
      ],
      "depends_on": {
        "db": {
          "condition": "service_started",
          "required": true
        }
      },
      "entrypoint": null,
      "environment": {
        "DATABASE_DB": "example",
        "DATABASE_HOST": "db",
        "DATABASE_PASSWORD": "/run/secrets/db-password",
        "DATABASE_USER": "root",
        "NODE_ENV": "development"
      },
      "networks": {
        "private": null,
        "public": null
      },
      "ports": [
        {
          "mode": "ingress",
          "target": 80,
          "published": "80",
          "protocol": "tcp"
        },
        {
          "mode": "ingress",
          "target": 9229,
          "published": "9229",
          "protocol": "tcp"
        },
        {
          "mode": "ingress",
          "target": 9230,
          "published": "9230",
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "source": "db-password",
          "target": "/run/secrets/db-password"
        }
      ],
      "volumes": [
        {
          "type": "bind",
          "source": "backend/src",
          "target": "/code/src",
          "read_only": true,
          "bind": {}
        },
        {
          "type": "bind",
          "source": "backend/package.json",
          "target": "/code/package.json",
          "bind": {}
        },
        {
          "type": "bind",
          "source": "backend/package-lock.json",
          "target": "/code/package-lock.json",
          "bind": {}
        },
        {
          "type": "volume",
          "source": "back-notused",
          "target": "/opt/app/node_modules",
          "volume": {}
        }
      ]
    },
    "db": {
      "command": [
        "--default-authentication-plugin=mysql_native_password"
      ],
      "entrypoint": null,
      "environment": {
        "MYSQL_DATABASE": "example",
        "MYSQL_ROOT_PASSWORD_FILE": "/run/secrets/db-password"
      },
      "image": "mariadb:10.6.4-focal",
      "networks": {
        "private": null
      },
      "restart": "always",
      "secrets": [
        {
          "source": "db-password",
          "target": "/run/secrets/db-password"
        }
      ],
      "volumes": [
        {
          "type": "volume",
          "source": "db-data",
          "target": "/var/lib/mysql",
          "volume": {}
        }
      ]
    },
    "frontend": {
      "build": {
        "context": "frontend",
        "dockerfile": "Dockerfile",
        "target": "development"
      },
      "command": null,
      "depends_on": {
        "backend": {
          "condition": "service_started",
          "required": true
        }
      },
      "entrypoint": null,
      "networks": {
        "public": null
      },
      "ports": [
        {
          "mode": "ingress",
          "target": 3000,
          "published": "3000",
          "protocol": "tcp"
        }
      ],
      "volumes": [
        {
          "type": "bind",
          "source": "frontend/src",
          "target": "/code/src",
          "bind": {}
        },
        {
          "type": "volume",
          "target": "/code/node_modules",
          "volume": {}
        }
      ]
    }
  },
  "volumes": {
    "back-notused": {
      "name": "flask_back-notused"
    },
    "db-data": {
      "name": "flask_db-data"
    }
  }
}