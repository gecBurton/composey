{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_cloudwatch_log_group": {
      "backend_lg": {
        "name": "/ecs/prod-flask-backend",
        "retention_in_days": 7
      },
      "frontend_lg": {
        "name": "/ecs/prod-flask-frontend",
        "retention_in_days": 7
      }
    },
    "aws_db_instance": {
      "db_db": {
        "allocated_storage": 20,
        "db_subnet_group_name": "${aws_db_subnet_group.db_sng.name}",
        "engine": "mariadb",
        "identifier": "prod-flask-db",
        "instance_class": "db.t3.micro",
        "password": "${random_password.db_password.result}",
        "publicly_accessible": false,
        "skip_final_snapshot": true,
        "username": "admin",
        "vpc_security_group_ids": [
          "${aws_security_group.app_sg.id}"
        ]
      }
    },
    "aws_db_subnet_group": {
      "db_sng": {
        "name": "prod-flask-db-sng",
        "subnet_ids": [
          "subnet-3",
          "subnet-4"
        ]
      }
    },
    "aws_ecs_service": {
      "backend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "backend",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.backend_tg.arn}"
          }
        ],
        "name": "prod-flask-backend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.backend_td.arn}"
      },
      "frontend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-flask-frontend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.frontend_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "backend_td": {
        "container_definitions": "[{\"name\": \"backend\", \"image\": \"placeholder\", \"essential\": true, \"command\": [\"npm\", \"run\", \"start-watch\"], \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [{\"name\": \"DATABASE_DB\", \"value\": \"example\"}, {\"name\": \"DATABASE_HOST\", \"value\": \"${aws_db_instance.db_db.address}\"}, {\"name\": \"DATABASE_PASSWORD\", \"value\": \"/run/secrets/db-password\"}, {\"name\": \"DATABASE_USER\", \"value\": \"root\"}, {\"name\": \"NODE_ENV\", \"value\": \"development\"}], \"secrets\": [{\"name\": \"DB_PASSWORD\", \"valueFrom\": \"${aws_secretsmanager_secret.backend_db-password_secret.arn}\"}, {\"name\": \"DB_PASSWORD\", \"valueFrom\": \"${aws_secretsmanager_secret.db_db_secret.arn}:password::\"}, {\"name\": \"DB_USERNAME\", \"valueFrom\": \"${aws_secretsmanager_secret.db_db_secret.arn}:username::\"}], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.backend_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.backend_exec_role.arn}",
        "family": "prod-flask-backend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.backend_task_role.arn}"
      },
      "frontend_td": {
        "container_definitions": "[{\"name\": \"frontend\", \"image\": \"placeholder\", \"essential\": true, \"portMappings\": [{\"containerPort\": 3000, \"hostPort\": 3000, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": [], \"logConfiguration\": {\"logDriver\": \"awslogs\", \"options\": {\"awslogs-group\": \"${aws_cloudwatch_log_group.frontend_lg.name}\", \"awslogs-region\": \"us-east-1\", \"awslogs-stream-prefix\": \"ecs\"}}}]",
        "cpu": "256",
        "execution_role_arn": "${aws_iam_role.frontend_exec_role.arn}",
        "family": "prod-flask-frontend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ],
        "task_role_arn": "${aws_iam_role.frontend_task_role.arn}"
      }
    },
    "aws_iam_role": {
      "backend_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-backend-exec-role"
      },
      "backend_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-backend-task-role"
      },
      "frontend_exec_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-frontend-exec-role"
      },
      "frontend_task_role": {
        "assume_role_policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Action\": \"sts:AssumeRole\", \"Effect\": \"Allow\", \"Principal\": {\"Service\": \"ecs-tasks.amazonaws.com\"}}]}",
        "name": "prod-flask-frontend-task-role"
      }
    },
    "aws_iam_role_policy": {
      "backend_back_notused_policy": {
        "name": "prod-flask-backend-back_notused-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_back_notused_bucket.arn}\", \"${aws_s3_bucket.backend_back_notused_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.backend_task_role.name}"
      },
      "backend_db-password_policy": {
        "name": "prod-flask-backend-db-password-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"secretsmanager:GetSecretValue\"], \"Resource\": [\"${aws_secretsmanager_secret.backend_db-password_secret.arn}\"]}]}",
        "role": "${aws_iam_role.backend_exec_role.name}"
      },
      "backend_exec_log_policy": {
        "name": "prod-flask-backend-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.backend_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.backend_exec_role.name}"
      },
      "backend_package_json_policy": {
        "name": "prod-flask-backend-package_json-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_package_json_bucket.arn}\", \"${aws_s3_bucket.backend_package_json_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.backend_task_role.name}"
      },
      "backend_package_lock_json_policy": {
        "name": "prod-flask-backend-package_lock_json-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_package_lock_json_bucket.arn}\", \"${aws_s3_bucket.backend_package_lock_json_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.backend_task_role.name}"
      },
      "backend_src_policy": {
        "name": "prod-flask-backend-src-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_src_bucket.arn}\", \"${aws_s3_bucket.backend_src_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.backend_task_role.name}"
      },
      "backend_to_db_rds_secret": {
        "name": "prod-flask-backend-db-rds-secret",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"secretsmanager:GetSecretValue\"], \"Resource\": [\"${aws_secretsmanager_secret.db_db_secret.arn}\"]}]}",
        "role": "${aws_iam_role.backend_exec_role.name}"
      },
      "frontend_exec_log_policy": {
        "name": "prod-flask-frontend-exec-log-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"logs:CreateLogStream\", \"logs:PutLogEvents\"], \"Resource\": [\"${aws_cloudwatch_log_group.frontend_lg.arn}:*\"]}]}",
        "role": "${aws_iam_role.frontend_exec_role.name}"
      },
      "frontend_src_policy": {
        "name": "prod-flask-frontend-src-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.frontend_src_bucket.arn}\", \"${aws_s3_bucket.frontend_src_bucket.arn}/*\"]}]}",
        "role": "${aws_iam_role.frontend_task_role.name}"
      }
    },
    "aws_lb_listener_rule": {
      "backend_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.backend_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "backend_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-flask-backend-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_s3_bucket": {
      "backend_back_notused_bucket": {
        "bucket": "prod-flask-backend-back-notused",
        "force_destroy": true
      },
      "backend_package_json_bucket": {
        "bucket": "prod-flask-backend-package-json",
        "force_destroy": true
      },
      "backend_package_lock_json_bucket": {
        "bucket": "prod-flask-backend-package-lock-json",
        "force_destroy": true
      },
      "backend_src_bucket": {
        "bucket": "prod-flask-backend-src",
        "force_destroy": true
      },
      "frontend_src_bucket": {
        "bucket": "prod-flask-frontend-src",
        "force_destroy": true
      }
    },
    "aws_secretsmanager_secret": {
      "backend_db-password_secret": {
        "description": "Secret db-password for flask service backend",
        "name": "prod-flask-backend-db-password"
      },
      "db_db_secret": {
        "description": "Credentials for db RDS",
        "name": "prod-flask-db-credentials"
      }
    },
    "aws_secretsmanager_secret_version": {
      "backend_db-password_secret_v1": {
        "lifecycle": {
          "ignore_changes": [
            "secret_string"
          ]
        },
        "secret_id": "${aws_secretsmanager_secret.backend_db-password_secret.id}",
        "secret_string": "PLACEHOLDER_VALUE_CHANGE_IN_AWS_CONSOLE"
      },
      "db_db_secret_v1": {
        "secret_id": "${aws_secretsmanager_secret.db_db_secret.id}",
        "secret_string": "{\"username\": \"admin\", \"password\": \"${random_password.db_password.result}\", \"engine\": \"mariadb\"}"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for flask in prod",
        "name": "prod-flask-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_backend_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to backend",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "app_egress_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow all outbound for flask in prod",
        "from_port": 0,
        "protocol": "-1",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 0,
        "type": "egress"
      },
      "backend_to_db_rule": {
        "description": "Allow backend to talk to db",
        "from_port": 3306,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 3306,
        "type": "ingress"
      },
      "frontend_to_backend_rule": {
        "description": "Allow frontend to talk to backend",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      }
    },
    "random_password": {
      "db_password": {
        "length": 20,
        "special": false
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      },
      "random": {
        "source": "hashicorp/random",
        "version": "~> 3.6"
      }
    }
  }
}