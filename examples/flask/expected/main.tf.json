{
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_ecs_service": {
      "backend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [
          {
            "container_name": "backend",
            "container_port": 80,
            "target_group_arn": "${aws_lb_target_group.backend_tg.arn}"
          }
        ],
        "name": "prod-flask-backend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.backend_td.arn}"
      },
      "db_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-flask-db",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.db_td.arn}"
      },
      "frontend_service": {
        "cluster": "arn:aws:ecs:us-east-1:123456789012:cluster/prod-cluster",
        "desired_count": 1,
        "launch_type": "FARGATE",
        "load_balancer": [],
        "name": "prod-flask-frontend",
        "network_configuration": {
          "assign_public_ip": false,
          "security_groups": [
            "${aws_security_group.app_sg.id}"
          ],
          "subnets": [
            "subnet-3",
            "subnet-4"
          ]
        },
        "task_definition": "${aws_ecs_task_definition.frontend_td.arn}"
      }
    },
    "aws_ecs_task_definition": {
      "backend_td": {
        "container_definitions": "[{\"name\": \"backend\", \"image\": \"placeholder\", \"essential\": true, \"portMappings\": [{\"containerPort\": 80, \"hostPort\": 80, \"protocol\": \"tcp\"}], \"environment\": [{\"name\": \"DATABASE_DB\", \"value\": \"example\"}, {\"name\": \"DATABASE_HOST\", \"value\": \"db\"}, {\"name\": \"DATABASE_PASSWORD\", \"value\": \"/run/secrets/db-password\"}, {\"name\": \"DATABASE_USER\", \"value\": \"root\"}, {\"name\": \"NODE_ENV\", \"value\": \"development\"}], \"secrets\": [{\"name\": \"DB_PASSWORD\", \"valueFrom\": \"${aws_secretsmanager_secret.backend_db-password_secret.arn}\"}]}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-flask-backend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      },
      "db_td": {
        "container_definitions": "[{\"name\": \"db\", \"image\": \"mariadb:10.6.4-focal\", \"essential\": true, \"portMappings\": [], \"environment\": [{\"name\": \"MYSQL_DATABASE\", \"value\": \"example\"}, {\"name\": \"MYSQL_ROOT_PASSWORD_FILE\", \"value\": \"/run/secrets/db-password\"}], \"secrets\": [{\"name\": \"DB_PASSWORD\", \"valueFrom\": \"${aws_secretsmanager_secret.db_db-password_secret.arn}\"}]}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-flask-db",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      },
      "frontend_td": {
        "container_definitions": "[{\"name\": \"frontend\", \"image\": \"placeholder\", \"essential\": true, \"portMappings\": [{\"containerPort\": 3000, \"hostPort\": 3000, \"protocol\": \"tcp\"}], \"environment\": [], \"secrets\": []}]",
        "cpu": "256",
        "execution_role_arn": "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy",
        "family": "prod-flask-frontend",
        "memory": "512",
        "network_mode": "awsvpc",
        "requires_compatibilities": [
          "FARGATE"
        ]
      }
    },
    "aws_iam_role_policy": {
      "backend_back_notused_policy": {
        "name": "prod-flask-backend-back_notused-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_back_notused_bucket.arn}\", \"${aws_s3_bucket.backend_back_notused_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      },
      "backend_package_json_policy": {
        "name": "prod-flask-backend-package_json-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_package_json_bucket.arn}\", \"${aws_s3_bucket.backend_package_json_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      },
      "backend_package_lock_json_policy": {
        "name": "prod-flask-backend-package_lock_json-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_package_lock_json_bucket.arn}\", \"${aws_s3_bucket.backend_package_lock_json_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      },
      "backend_src_policy": {
        "name": "prod-flask-backend-src-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.backend_src_bucket.arn}\", \"${aws_s3_bucket.backend_src_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      },
      "db_db_data_policy": {
        "name": "prod-flask-db-db_data-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.db_db_data_bucket.arn}\", \"${aws_s3_bucket.db_db_data_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      },
      "frontend_src_policy": {
        "name": "prod-flask-frontend-src-policy",
        "policy": "{\"Version\": \"2012-10-17\", \"Statement\": [{\"Effect\": \"Allow\", \"Action\": [\"s3:*\"], \"Resource\": [\"${aws_s3_bucket.frontend_src_bucket.arn}\", \"${aws_s3_bucket.frontend_src_bucket.arn}/*\"]}]}",
        "role": "execution_role_placeholder"
      }
    },
    "aws_lb_listener_rule": {
      "backend_listener_rule": {
        "action": [
          {
            "target_group_arn": "${aws_lb_target_group.backend_tg.arn}",
            "type": "forward"
          }
        ],
        "condition": [
          {
            "path_pattern": {
              "values": [
                "/*"
              ]
            }
          }
        ],
        "listener_arn": "arn:aws:lb:us-east-1:123456789012:listener/app/shared-alb/123/456",
        "priority": 100
      }
    },
    "aws_lb_target_group": {
      "backend_tg": {
        "health_check": {
          "enabled": true,
          "matcher": "200-399",
          "path": "/"
        },
        "name": "prod-flask-backend-tg",
        "port": 80,
        "protocol": "HTTP",
        "target_type": "ip",
        "vpc_id": "vpc-123"
      }
    },
    "aws_s3_bucket": {
      "backend_back_notused_bucket": {
        "bucket": "prod-flask-backend-back-notused",
        "force_destroy": true
      },
      "backend_package_json_bucket": {
        "bucket": "prod-flask-backend-package-json",
        "force_destroy": true
      },
      "backend_package_lock_json_bucket": {
        "bucket": "prod-flask-backend-package-lock-json",
        "force_destroy": true
      },
      "backend_src_bucket": {
        "bucket": "prod-flask-backend-src",
        "force_destroy": true
      },
      "db_db_data_bucket": {
        "bucket": "prod-flask-db-db-data",
        "force_destroy": true
      },
      "frontend_src_bucket": {
        "bucket": "prod-flask-frontend-src",
        "force_destroy": true
      }
    },
    "aws_secretsmanager_secret": {
      "backend_db-password_secret": {
        "description": "Secret db-password for flask service backend",
        "name": "prod-flask-backend-db-password"
      },
      "db_db-password_secret": {
        "description": "Secret db-password for flask service db",
        "name": "prod-flask-db-db-password"
      }
    },
    "aws_security_group": {
      "app_sg": {
        "description": "Security group for flask in prod",
        "name": "prod-flask-sg",
        "vpc_id": "vpc-123"
      }
    },
    "aws_security_group_rule": {
      "alb_to_backend_rule": {
        "cidr_blocks": [
          "0.0.0.0/0"
        ],
        "description": "Allow ALB to talk to backend",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "backend_to_db_rule": {
        "description": "Allow backend to talk to db",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      },
      "frontend_to_backend_rule": {
        "description": "Allow frontend to talk to backend",
        "from_port": 80,
        "protocol": "tcp",
        "security_group_id": "${aws_security_group.app_sg.id}",
        "source_security_group_id": "${aws_security_group.app_sg.id}",
        "to_port": 80,
        "type": "ingress"
      }
    }
  },
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  }
}